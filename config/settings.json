{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git push:*)",
      "Bash(php artisan:*)",
      "Bash(vendor/bin/pint:*)",
      "mcp__laravel-boost__tinker",
      "mcp__sequential-thinking__sequentialthinking",
      "/commit"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "dontAsk"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/bin/claude-cli audit"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/telegram-patch.sh",
            "async": true
          },
          {
            "type": "command",
            "command": "$HOME/.claude/bin/claude-cli selfupdate"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$HOME/.claude/bin/claude-cli statusline"
  },
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "expo-app-design@expo-plugins": true,
    "upgrading-expo@expo-plugins": true,
    "expo-deployment@expo-plugins": true,
    "telegram@claude-plugins-official": true
  },
  "autoUpdatesChannel": "latest",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
