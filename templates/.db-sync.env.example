# Production Database Sync Configuration
# Copy this file to .db-sync.env and fill in your credentials
# NEVER commit .db-sync.env - it contains production secrets

# Application name — used for backup file naming and local dev URL
# Defaults to the repository folder name if not set
APP_NAME=myapp

# SSH Connection (Laravel Forge)
SSH_USER=forge
SSH_HOST=your-server-ip
SSH_PORT=22
# Leave empty to use SSH agent (1Password, ssh-agent, etc.)
# Or set a path: ~/.ssh/id_rsa
SSH_KEY=

# Production Database (on the server, accessed via SSH tunnel)
PROD_DB_HOST=127.0.0.1
PROD_DB_PORT=3306
PROD_DB_NAME=your-db-name
PROD_DB_USER=forge
PROD_DB_PASS=your-db-password

# Local Database (Herd MySQL)
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=3306
LOCAL_DB_NAME=myapp
LOCAL_DB_USER=root
LOCAL_DB_PASS=

# Tables to exclude from dump (comma-separated, no spaces)
# Leave empty to dump everything
EXCLUDE_TABLES=
